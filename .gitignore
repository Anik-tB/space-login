# Dependencies - DO NOT COMMIT
/vendor/
/node_modules/

# Environment Configuration
.env
.env.local
.env.*.local

# User Uploads (keep structure, ignore content)
/uploads/evidence/*
!/uploads/evidence/.gitkeep

# IDE and Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Logs and Debugging
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
error_log
debug.log

# Temporary Files
*.tmp
*.temp
*.cache
*.bak
*.backup
*~

# Build and Distribution
/dist/
/build/
/public/build/

# Package Manager Locks (optional - uncomment if needed)
# package-lock.json
# composer.lock

# Database Backups (keep schema, ignore data dumps)
*_backup.sql
*_dump.sql

# PHP Specific
*.php~
.phpunit.result.cache

# Compiled Files
*.com
*.class
*.dll
*.exe
*.o
*.so

# Archives
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Firebase Private Keys (if any)
firebase-adminsdk-*.json
serviceAccountKey.json

# Session Files
/sessions/
*.sess

# Coverage Reports
/coverage/
.nyc_output/

# Optional: Ignore large media files if needed
# *.mp4
# *.mov
# *.avi
